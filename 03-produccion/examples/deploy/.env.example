# Copiar a `.env` (gitignored) y completar. Estas variables las lee
# ServiceSettings (prod_lib.py) y el docker-compose.
#
# REGLA: el `.env` con valores reales NUNCA se commitea. Solo este `.example`.

# --- LLM (§2) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-REEMPLAZAR
# ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR

# --- Postgres + pgvector (las usa el compose y DATABASE_URL) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=cambiar-en-local
POSTGRES_DB=rag
DATABASE_URL=postgresql://rag:cambiar-en-local@db:5432/rag

# --- Redis (cache compartido multi-réplica, §4/§7) ---
REDIS_URL=redis://cache:6379/0

# --- Knobs del RAG (opcionales; tienen defaults en ServiceSettings) ---
K_DEFAULT=3
TEMPERATURE=0.0
MAX_TOKENS=512
PROMPT_NAME=rag-fiscal
# PROMPT_VERSION=v2          # vacío = última

# --- Caché (§4) ---
RESPONSE_CACHE_SIZE=2048
RESPONSE_CACHE_TTL_S=3600
SEMANTIC_THRESHOLD=0.7

# --- Reliability (§6) ---
RATE_LIMIT_RPS=10
MAX_RETRIES=3
BREAKER_FAILURE_THRESHOLD=5
LLM_TIMEOUT_S=30

# --- Ops (§5) ---
LOG_LEVEL=INFO
SERVICE_VERSION=0.1.0
